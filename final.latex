\section{Akış Şeması (Flowchart)}

\begin{figure}[H]
\centering
\scalebox{0.78}{
\begin{tikzpicture}[
  startstop/.style={draw, ellipse, fill=green!25, draw=green!55!black,
                    minimum width=3.2cm, minimum height=0.9cm,
                    font=\small\bfseries},
  process/.style={draw, rectangle, rounded corners=4pt, fill=blue!10,
                  draw=blue!55!black, minimum width=5.4cm,
                  minimum height=1.0cm, font=\small, align=center, thick},
  decision/.style={draw, diamond, aspect=3.2, fill=yellow!20,
                   draw=orange!65!black, font=\small, align=center,
                   inner sep=3pt, thick},
  interrupt/.style={draw, rectangle, fill=red!12, draw=red!55!black,
                    rounded corners=4pt, minimum width=5.4cm,
                    minimum height=1.0cm, font=\small\bfseries, align=center, thick},
  arrow/.style={-Stealth, thick, blue!60!black},
  darrow/.style={-Stealth, thick, dashed, gray!70!black},
]

% ────────────────────────────────────────────
%  SAĞ SÜTUN: Ana Başlangıç Akışı  (x = 5)
% ────────────────────────────────────────────
\node[startstop] (start) at (5,  0.0) {BAŞLA};
\node[process]   (init)  at (5, -2.0) {Sistem Başlangıcı\\ADC, TIM2, TIM3, UART, DMA};
\node[process]   (pwm)   at (5, -4.0) {TIM2 PWM + TRGO Başlat};
\node[process]   (dma)   at (5, -6.0) {DMA + Normal ADC Taramayı Başlat};
\node[process]   (while) at (5, -8.0) {{\bfseries Ana Döngü (while)}\\Boşta -- Düşük Güç};

% Ana akış okları (düz aşağı)
\draw[arrow] (start) -- (init);
\draw[arrow] (init)  -- (pwm);
\draw[arrow] (pwm)   -- (dma);
\draw[arrow] (dma)   -- (while);

% ────────────────────────────────────────────
%  SOL SÜTUN: TIM3 ISR Akışı  (x = -2.5)
% ────────────────────────────────────────────
\node[interrupt] (tim3)  at (-2.5, -8.0)  {TIM3 Kesmesi (100 ms)};
\node[process]   (rcurr) at (-2.5, -10.2) {DMA Tampondan Akım Oku};
\node[process]   (rinj)  at (-2.5, -12.4) {ADC Verilerini Oku (CH0..CH3)};
\node[process]   (soc)   at (-2.5, -14.6) {SoC Hesapla (Coulomb Counting)};
\node[decision]  (dec)   at (-2.5, -17.0) {Voltaj\\Dustu?};
\node[process]   (safe)  at (-2.5, -19.4) {Yükü Kes (PB8=0)\\Hata LED + UART Uyarı};
\node[interrupt] (isr)   at (-2.5, -21.6) {ISR Sonu};

% Hayır dalı -- sağda ayrı kutu (x = 3.5)
\node[process]   (norm)  at (3.5,  -17.0) {Normal Izleme\\LED + UART Güncelle};

% ── ISR iç okları (düz aşağı) ──
\draw[arrow] (tim3)  -- (rcurr);
\draw[arrow] (rcurr) -- (rinj);
\draw[arrow] (rinj)  -- (soc);
\draw[arrow] (soc)   -- (dec);

% Evet: aşağı → safe
\draw[arrow] (dec.south) -- node[right, font=\footnotesize]{Evet} (safe.north);

% Hayır: sağa → norm
\draw[arrow] (dec.east) -- node[above, font=\footnotesize]{Hayır} (norm.west);

% norm'dan ISR sona bağlan (L-şekli, sağdan döner)
\draw[arrow] (norm.south) -- ++(0,-0.6) -| (isr.east);

% safe → ISR sonu (düz)
\draw[arrow] (safe) -- (isr);

% ────────────────────────────────────────────
%  BAĞLANTI OKLARI (Dış kenarlarda)
% ────────────────────────────────────────────

% while → TIM3 ISR  (aynı y hizasında, yatay ok)
\draw[arrow] (while.west)
    -- node[above, font=\footnotesize\itshape]{Kesme Tetikler}
    (tim3.east);

% ISR Sonu → while (dışarıdan dönen kesikli ok)
% isr.south → aşağı → sağa → yukarı → while.east
\draw[darrow]
    (isr.south)
    -- ++(0, -0.9)
    -- ++(11.2, 0)
    -- ++(0, 14.5)
    -- node[right, font=\footnotesize\itshape]{ISR Geri Dön}
    (while.east);

\end{tikzpicture}
}
\caption{BMS Simülatörü -- Yazılım Akış Şeması}
\label{fig:flowchart}
\end{figure}

\subsection{Akış Şeması Açıklamaları}

\begin{itemize}
  \item \textbf{Ana Döngü (while):} Her 150~ms'de bir \texttt{BMS\_Update()}
    çağrılır. Bu fonksiyon, DMA tamponundan güncel ADC değerlerini okur,
    SoC hesaplar ve röle/LED durumunu günceller.

  \item \textbf{TIM3 Kesmesi:} Her 100~ms'de bir tetiklenir. Ana kontrol
    döngüsü ile senkronizasyon sağlar.

  \item \textbf{Voltaj Çökmesi Kararı:} Normal ADC (CH2--CH3) üzerinden
    okunan hücre voltajı eşik değerin ($V_{\min} = 3{,}0$~V/hücre) altına
    düştüğünde yük anında kesilir.

  \item \textbf{Coulomb Counting (SoC):}
    \[
      \text{SoC}(t) = \text{SoC}(0) - \frac{1}{C_{\text{nom}}}
      \int_{0}^{t} I(\tau)\,d\tau
    \]
    Sayısal integral Euler yöntemiyle yaklaşık olarak hesaplanır.
\end{itemize}

