  ymin=2.8, ymax=4.4,
  xtick={0,20,50,80,100},
  ytick={3.0,3.2,3.4,3.6,3.8,4.0,4.2,4.4},
  grid=both,
  grid style={line width=0.3pt, draw=gray!30},
  major grid style={line width=0.5pt, draw=gray!60},
  legend pos=north west,
  legend style={font=\small},
  tick label style={font=\small},
  label style={font=\small},
]
% Deşarj eğrisi
\addplot[blue!70!black, thick, mark=*, mark size=2pt]
  coordinates {(0,3.00)(20,3.55)(50,3.75)(80,3.95)(100,4.20)};
\addlegendentry{Deşarj (OCV)}

% Şarj eğrisi
\addplot[red!70!black, thick, dashed, mark=square*, mark size=2pt]
  coordinates {(0,3.10)(20,3.65)(50,3.85)(80,4.05)(100,4.20)};
\addlegendentry{Şarj (OCV)}

% Voltage Drop eşiği
\addplot[orange!80!black, thick, dotted, domain=0:100] {3.0};
\addlegendentry{$V_{\min}$ eşiği (3{,}0 V)}

% Histerezis bandı göstergesi
\draw[<->, gray!60!black, thin]
  (axis cs:50,3.75) -- (axis cs:50,3.85)
  node[midway, right, font=\tiny]{$\Delta V \approx 0{,}1$~V};
\end{axis}
\end{tikzpicture}
\caption{Li-iyon Hücre OCV--SoC Eğrisi (Şarj/Deşarj Histerezisi)}
\label{fig:ocv_curve}
\end{figure}

\subsubsection*{Yazılım Uygulama Yöntemi}

Yazılımda OCV--SoC dönüşümü aşağıdaki şekilde gerçekleştirilir:

\begin{lstlisting}[language=C, caption={Non-lineer OCV--SoC Lookup (Gerçek Uygulama)}]
/* bms.c */
static const float ocv_soc[5]       = {0.0f, 20.0f, 50.0f, 80.0f, 100.0f};
static const float ocv_discharge[5] = {3.00f, 3.55f, 3.75f, 3.95f, 4.20f};
static const float ocv_charge[5]    = {3.10f, 3.65f, 3.85f, 4.05f, 4.20f};

float BMS_VoltageToSoC(float v_cell) {
    if (v_cell <= ocv_discharge[0]) return 0.0f;
    if (v_cell >= ocv_discharge[4]) return 100.0f;
    for (int i = 0; i < 4; i++) {
        if (v_cell >= ocv_discharge[i]
         && v_cell < ocv_discharge[i+1]) {
            float ratio = (v_cell - ocv_discharge[i])
                        / (ocv_discharge[i+1] - ocv_discharge[i]);
            return ocv_soc[i]
                 + ratio * (ocv_soc[i+1] - ocv_soc[i]);
        }
    }
    return 0.0f;
}
\end{lstlisting}

\begin{lstlisting}[language=C, caption={BMS Durum Yapisi (Gerçek Uygulama)}]
/* bms.h */
typedef enum {
    BMS_STATE_IDLE      = 0,
    BMS_STATE_CHARGE    = 1,
    BMS_STATE_DISCHARGE = 2,
    BMS_STATE_FAULT     = 3,
} BMS_StateTypeDef;

typedef struct {
    float cell_voltage[2];    /* Injected ADC results [V] */
    float current[2];         /* Normal ADC current [A]   */
    float soc;                /* State of Charge [%]      */
    BMS_StateTypeDef state;
    uint8_t load_connected;
} BMS_HandleTypeDef;
\end{lstlisting}

\subsection{Injected ADC ve Normal ADC Etkileşimi}

\begin{lstlisting}[language=C, caption={ADC Konfigürasyonu (Final -- 4 Regular + DMA)}]
/* adc_handler.c -- 4 kanal, Scan Mode + DMA */
hadc1.Init.NbrOfConversion = 4;  /* CH0..CH3 */

/* CH0: PA0 -- Akim 1 */
sConfig.Channel = ADC_CHANNEL_0;
sConfig.Rank = ADC_REGULAR_RANK_1;
HAL_ADC_ConfigChannel(&hadc1, &sConfig);
/* CH1: PA1 -- Akim 2 */
sConfig.Channel = ADC_CHANNEL_1;
sConfig.Rank = ADC_REGULAR_RANK_2;
HAL_ADC_ConfigChannel(&hadc1, &sConfig);
/* CH2: PA2 -- Hucre 1 Voltaj */
sConfig.Channel = ADC_CHANNEL_2;
sConfig.Rank = ADC_REGULAR_RANK_3;
HAL_ADC_ConfigChannel(&hadc1, &sConfig);
/* CH3: PA3 -- Hucre 2 Voltaj */
sConfig.Channel = ADC_CHANNEL_3;
sConfig.Rank = ADC_REGULAR_RANK_4;
HAL_ADC_ConfigChannel(&hadc1, &sConfig);

void ADC_Start(void) {
    HAL_ADC_Start_DMA(&hadc1, (uint32_t *)adc_buffer, 4);
}

float ADC_GetCellVoltage(uint8_t cell) {
    uint16_t raw = adc_buffer[cell + 2]; /* CH2, CH3 */
    float scale = (ADC_VREF / ADC_RESOLUTION)
                * ((R1 + R2) / R2);
    return (float)raw * scale;
}
\end{lstlisting}

